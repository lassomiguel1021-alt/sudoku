<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.univalle.sudoku.controllers.InicioController">
   <children>
      <VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="SUDOKU">
               <font>
                  <Font name="System Bold" size="48.0" />
               </font>
            </Label>
            <Button fx:id="btnJugar" mnemonicParsing="false" onAction="#onJugarClick" prefHeight="40.0" prefWidth="200.0" text="Jugar" />
            <Button fx:id="btnReglas" mnemonicParsing="false" onAction="#onReglasClick" prefHeight="40.0" prefWidth="200.0" text="Reglas" />
         </children>
      </VBox>
   </children>
</AnchorPane>
